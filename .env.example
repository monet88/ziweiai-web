# Biến môi trường cấp workspace — MỘT file .env DUY NHẤT ở root cho cả backend lẫn web.
# - Backend (@ziweiai/api): đọc .env gần nhất theo walk-up (apps/api/src/config/env.ts).
# - Web (@ziweiai/web): Vite envDir + SvelteKit kit.env.dir đều trỏ về root (apps/web/vite.config.ts
#   + svelte.config.js), nên client đọc PUBLIC_* ngay tại file này. KHÔNG còn apps/web/.env riêng.
#
# Bất biến bảo mật: chỉ PUBLIC_* được bundle ra client; secret server-only KHÔNG bao giờ đặt PUBLIC_*.
# TUYỆT ĐỐI KHÔNG commit giá trị thật. Đây chỉ là file mẫu với placeholder.

# --- Web client-safe (PUBLIC_*) — bundle ra client ---
PUBLIC_API_BASE_URL=http://localhost:3000
# Supabase Cloud (decision 0016): project ziweiai-web. URL công khai, anon/publishable key
# có thể bundle ra client theo thiết kế Supabase. Lấy giá trị thật:
#   supabase projects api-keys --project-ref uaicvwttnajeglxiorpb -o env
PUBLIC_SUPABASE_URL=https://uaicvwttnajeglxiorpb.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key

# --- HTTP / CORS ---
API_PORT=3000
API_SERVICE_NAME=ziweiai-api
API_CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:3000

# --- Rate limit (đều có default trong schema, override khi cần) ---
API_REQUESTS_PER_MINUTE_PER_IP=60
API_REQUESTS_PER_MINUTE_PER_USER=30
API_CHARTS_PER_DAY_PER_USER=20
API_EXPLANATIONS_PER_DAY_PER_USER=50

# --- Quota counter store (US-013): bền hoá trần daily-per-IP cho đường ẩn danh ---
# memory  = in-memory (mặc định, dev/test — không cần dependency ngoài, không bền qua restart)
# upstash = Upstash Redis REST qua fetch (prod — chia sẻ đa-instance, bền qua restart)
# redis   = chưa triển khai (factory sẽ ném lỗi nếu chọn)
QUOTA_STORE_DRIVER=memory
# Khi store ngoài down: open = cho qua + log warn (mặc định); closed = chặn (ném quota error)
QUOTA_FAIL_MODE=open
# Bắt buộc khi QUOTA_STORE_DRIVER=upstash:
# QUOTA_UPSTASH_REST_URL=https://your-db.upstash.io
# QUOTA_UPSTASH_REST_TOKEN=your-upstash-rest-token
# Dành cho đường upgrade redis (chưa dùng):
# QUOTA_REDIS_URL=

# --- Supabase (secret server-only — không bao giờ lộ qua PUBLIC_*) ---
# Supabase Cloud (decision 0016). SERVICE_ROLE_KEY + JWT_SECRET là secret, KHÔNG commit giá
# trị thật. SUPABASE_JWT_SECRET chỉ cần cho project dùng HS256 shared secret; project mới mặc
# định JWT asymmetric (verify qua JWKS), khi đó có thể để placeholder.
SUPABASE_URL=https://uaicvwttnajeglxiorpb.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret-at-least-32-characters-long
# Management API token (sbp_*) — dùng để chạy migration/SQL lên cloud qua api.supabase.com.
SUPABASE_ACCESS_TOKEN=sbp_your-management-access-token
# Cloud Postgres password + connection string (pooler ap-southeast-1, port 6543).
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<password>@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# --- AI providers (để trống thì provider tự skip) ---
AI_PROVIDER_TIMEOUT_MS=15000
# Provider mà preference 'auto' ưu tiên: auto | deepseek | openai-compat | gemini
# 'auto' dùng thứ tự chain gốc của router: openai-compat → deepseek → gemini.
# Đặt giá trị cụ thể để ép một provider lên đầu chain (vẫn giữ phần còn lại làm fallback).
AI_DEFAULT_PROVIDER=auto

# --- AI explanation gating (US-010) ---
# true = free for all during test (gate is no-op)
# MUST set to false in production when real billing is live
AI_EXPLANATION_FREE_FOR_ALL=true

# --- Extended divination systems (US-017) ---
# Default false: framework/API contract exists, but each system is enabled only after its epic is ready.
EXTENDED_SYSTEM_HEPAN_ENABLED=false
EXTENDED_SYSTEM_MANGPAI_ENABLED=false
EXTENDED_SYSTEM_TAROT_ENABLED=false
EXTENDED_SYSTEM_MBTI_ENABLED=false
EXTENDED_SYSTEM_FACE_ENABLED=false
EXTENDED_SYSTEM_PALM_ENABLED=false
# B6 net-new systems (US-037/038/039): Lenormand / Giải mộng / Xin xăm. Same fail-closed default.
EXTENDED_SYSTEM_LENORMAND_ENABLED=false
EXTENDED_SYSTEM_DREAM_ENABLED=false
EXTENDED_SYSTEM_STICKS_ENABLED=false
# B6 almanac system (US-040): Hoàng lịch (chọn ngày tốt). Same fail-closed default.
EXTENDED_SYSTEM_ALMANAC_ENABLED=false
# Separate daily quota for vision (face/palm) — much more expensive than text.
API_VISION_REQUESTS_PER_DAY_PER_USER=5

# --- Annual report AI gate (US-016) ---
# Đường báo cáo năm (LLM tổng hợp lưu niên + 12 lưu nguyệt) tốn token cao nên có
# phanh riêng + quota riêng, độc lập với AI_EXPLANATION_FREE_FOR_ALL.
# false (mặc định, fail-closed) = đường sinh báo cáo mới trả 402; cache-hit vẫn xem được.
AI_ANNUAL_REPORT_ENABLED=false
API_ANNUAL_REPORTS_PER_DAY_PER_USER=2

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro

OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=https://api.openai.com
OPENAI_COMPAT_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
