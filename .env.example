# Biến môi trường cấp workspace cho BACKEND (@ziweiai/api).
# API đọc file .env gần nhất theo cơ chế walk-up (xem apps/api/src/config/env.ts).
# Web (@ziweiai/web) KHÔNG đọc file này — client chỉ dùng PUBLIC_* trong apps/web/.env.
#
# TUYỆT ĐỐI KHÔNG commit giá trị thật. Đây chỉ là file mẫu với placeholder.

# --- HTTP / CORS ---
API_PORT=3000
API_SERVICE_NAME=ziweiai-api
API_CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:3000

# --- Rate limit (đều có default trong schema, override khi cần) ---
API_REQUESTS_PER_MINUTE_PER_IP=60
API_REQUESTS_PER_MINUTE_PER_USER=30
API_CHARTS_PER_DAY_PER_USER=20
API_EXPLANATIONS_PER_DAY_PER_USER=50

# --- Quota counter store (US-013): bền hoá trần daily-per-IP cho đường ẩn danh ---
# memory  = in-memory (mặc định, dev/test — không cần dependency ngoài, không bền qua restart)
# upstash = Upstash Redis REST qua fetch (prod — chia sẻ đa-instance, bền qua restart)
# redis   = chưa triển khai (factory sẽ ném lỗi nếu chọn)
QUOTA_STORE_DRIVER=memory
# Khi store ngoài down: open = cho qua + log warn (mặc định); closed = chặn (ném quota error)
QUOTA_FAIL_MODE=open
# Bắt buộc khi QUOTA_STORE_DRIVER=upstash:
# QUOTA_UPSTASH_REST_URL=https://your-db.upstash.io
# QUOTA_UPSTASH_REST_TOKEN=your-upstash-rest-token
# Dành cho đường upgrade redis (chưa dùng):
# QUOTA_REDIS_URL=

# --- Supabase (secret server-only — không bao giờ lộ qua PUBLIC_*) ---
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret-at-least-32-characters-long

# --- AI providers (để trống thì provider tự skip) ---
AI_PROVIDER_TIMEOUT_MS=15000
# Provider mà preference 'auto' ưu tiên: auto | deepseek | openai-compat | gemini
AI_DEFAULT_PROVIDER=auto

# --- AI explanation gating (US-010) ---
# true = free for all during test (gate is no-op)
# MUST set to false in production when real billing is live
AI_EXPLANATION_FREE_FOR_ALL=true

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro

OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=https://api.openai.com
OPENAI_COMPAT_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
