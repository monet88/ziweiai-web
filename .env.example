# Expo client-safe values only. These may be bundled into the app.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# API runtime values. Do not expose these through EXPO_PUBLIC_*.
API_PORT=3000
API_SERVICE_NAME=ziweiai-api
API_CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000

# Server-only secrets for later phases. Never commit real values.
SUPABASE_SERVICE_ROLE_KEY=
DEEPSEEK_API_KEY=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=https://api.openai.com
OPENAI_COMPAT_MODEL=gpt-4o-mini
GEMINI_API_KEY=
# Provider mà preference 'auto' ưu tiên: auto | deepseek | openai-compat | gemini
AI_DEFAULT_PROVIDER=auto
GEOCODING_API_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
